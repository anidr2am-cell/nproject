rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function adminEmail() {
      return signedIn() && request.auth.token.email != null
        ? request.auth.token.email
        : "";
    }

    function isAdmin() {
      return signedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/admins/$(adminEmail()))
      );
    }

    function listingOwner() {
      return signedIn() && resource.data.sellerUid == request.auth.uid;
    }

    function listingCreator() {
      return signedIn() && request.resource.data.sellerUid == request.auth.uid;
    }

    function chatParticipant() {
      return signedIn() && request.auth.uid in resource.data.participantIds;
    }

    function chatCreatorParticipant() {
      return signedIn() &&
        request.auth.uid in request.resource.data.participantIds;
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create: if listingCreator();
      allow update, delete: if listingOwner() || isAdmin();
    }

    match /realEstate/{listingId} {
      allow read: if true;
      allow create: if listingCreator();
      allow update, delete: if listingOwner() || isAdmin();
    }

    match /admins/{adminId} {
      allow get: if signedIn() && (
        adminId == request.auth.uid ||
        adminId == adminEmail()
      );
      allow list: if false;
      allow create, update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /locations/{locationId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow create, read, update, delete: if owns(userId) || isAdmin();

      match /favorites/{listingId} {
        allow read, create, update, delete: if owns(userId);
      }

      match /notifications/{notificationId} {
        allow read, update, delete: if owns(userId);
        allow create: if signedIn();
      }

      match /hiddenListings/{listingId} {
        allow read, create, update, delete: if owns(userId);
      }

      match /blockedUsers/{blockedUserId} {
        allow read, create, update, delete: if owns(userId);
      }
    }

    match /chatRooms/{roomId} {
      allow create: if chatCreatorParticipant();
      allow read, update, delete: if chatParticipant();

      match /messages/{messageId} {
        allow create: if signedIn() &&
          request.auth.uid == request.resource.data.senderUid &&
          request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participantIds;
        allow read, update, delete: if signedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participantIds;
      }
    }

    match /reports/{reportId} {
      allow create: if signedIn() &&
        request.resource.data.reporterUid == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    match /notices/{noticeId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
